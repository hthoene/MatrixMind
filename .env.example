MATRIX_HOMESERVER_URL=https://matrix.example.com
MATRIX_ACCESS_TOKEN=syt_...
MATRIX_USER_ID=@matrixmind:example.com
# Only required for the one-time cross-signing bootstrap on first start.
# Can be removed from .env after the first successful startup.
MATRIX_PASSWORD=
# Recommended for Docker and headless setups: if your account already has
# Secret Storage / cross-signing, MatrixMind can unlock it automatically and
# verify its own device without SAS emojis.
MATRIX_RECOVERY_KEY=
MATRIX_AUTO_VERIFY=true
# Optional fallback if you prefer file-based confirmation instead of the HTTP
# confirmation endpoint logged by MatrixMind.
MATRIX_AUTO_VERIFY_RESPONSE_FILE=
# Optional status file written during automatic verification.
MATRIX_AUTO_VERIFY_STATUS_FILE=./workspaces/verify-status.json
# Optional: pin auto-verification to a specific own Element device ID.
MATRIX_AUTO_VERIFY_TARGET_DEVICE_ID=
# Safety switch: only set to true if you intentionally want MatrixMind to wipe
# inaccessible SSSS/cross-signing state and create fresh keys.
MATRIX_ALLOW_CROSS_SIGNING_RESET=false
ANTHROPIC_API_KEY=sk-ant-...
KIE_AI_API_KEY=
# Comma-separated list of homeservers whose members are allowed to chat with the bot.
# The bot only responds in rooms where at least one member comes from one of these servers.
# Leave empty to allow everyone.
# Example: ALLOWED_HOMESERVERS=quassel.io,example.com
ALLOWED_HOMESERVERS=
CLAUDE_CODE_AVAILABLE=true
CHROMADB_URL=http://chromadb:8000
BOT_COMMAND_PREFIX=!
REPLY_COOLDOWN_MS=5000
MAX_REQUESTS_PER_ROOM_PER_MINUTE=10
PYTHON_EXECUTION_TIMEOUT_MS=30000
LOG_LEVEL=info
WORKSPACES_DIR=./workspaces
